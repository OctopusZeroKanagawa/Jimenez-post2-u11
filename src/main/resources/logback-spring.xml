<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Appender CONSOLA ───────────────────────────────────────────── -->
    <appender name="CONSOLA" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{30} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Appender ARCHIVO con rotación diaria (30 días historial) ──── -->
    <appender name="ARCHIVO"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/catalogo.log</file>
        <rollingPolicy
                class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Rotación diaria: crea un archivo por día -->
            <fileNamePattern>logs/catalogo.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- Conserva los últimos 30 días de historial -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Nivel DEBUG para el paquete de la aplicación -->
    <logger name="com.empresa.catalogo" level="DEBUG"/>

    <!-- Nivel INFO global — escribe en consola y archivo -->
    <root level="INFO">
        <appender-ref ref="CONSOLA"/>
        <appender-ref ref="ARCHIVO"/>
    </root>

</configuration>
